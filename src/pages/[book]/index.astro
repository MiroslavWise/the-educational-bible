---
import { getCollection } from "astro:content"
import type { Thing } from "schema-dts"
import Layout from "../../layouts/Layout.astro"
import BookPage from "../../components/BookPage"
import {
  OG_IMAGE_PATH,
  SITE_NAME,
  absoluteUrl,
  bookDescription,
  bookKeywords,
  bookTitle,
} from "../../lib/seo"
import {
  getVideosForBook,
  youtubeEmbedUrl,
  youtubeThumbUrl,
  youtubeWatchUrl,
} from "../../lib/videos"

export async function getStaticPaths() {
  const entries = await getCollection("books")
  return entries.map((e) => ({
    params: { book: e.data.slug },
    props: { data: e.data },
  }))
}

const { data } = Astro.props
const book = {
  slug: data.slug,
  name: data.name,
  fullName: data.fullName,
  testament: data.testament,
  chaptersCount: data.chaptersCount,
  introduction: data.introduction,
  articles: data.articles,
}

const videos = getVideosForBook(data.slug)
const introText = data.introduction
  .flatMap((s) => s.paragraphs)
  .find((p) => p.trim().length > 40)

const path = `/${data.slug}/`
const title = bookTitle(data.fullName)
const description = bookDescription(data.fullName, data.chaptersCount, introText)
const keywords = bookKeywords(data.name, data.fullName)
const pageUrl = absoluteUrl(path, Astro.site)
const imageUrl = absoluteUrl(OG_IMAGE_PATH, Astro.site)
const homeUrl = Astro.site?.href ?? "https://the-educational-bible.web.app/"

const jsonLd: Thing[] = [
  {
    "@type": "Book",
    name: data.fullName,
    alternateName: data.name,
    url: pageUrl,
    inLanguage: "ru",
    numberOfPages: data.chaptersCount,
    description,
    keywords,
    image: imageUrl,
    isPartOf: {
      "@type": "Book",
      name: SITE_NAME,
      url: homeUrl,
    },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Главная",
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: data.name,
        item: pageUrl,
      },
    ],
  },
]

const firstVideo = videos[0]
if (firstVideo) {
  jsonLd.push({
    "@type": "VideoObject",
    name: firstVideo.title,
    description: `${firstVideo.title} — обзор книги «${data.fullName}» (BibleProject)`,
    thumbnailUrl: youtubeThumbUrl(firstVideo.id),
    embedUrl: youtubeEmbedUrl(firstVideo.id),
    contentUrl: youtubeWatchUrl(firstVideo.id),
    inLanguage: "ru",
    isPartOf: {
      "@type": "Book",
      name: data.fullName,
      url: pageUrl,
    },
  })
}
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  path={path}
  ogType="book"
  jsonLd={jsonLd}
>
  <BookPage client:load book={book} videos={videos} />
</Layout>
