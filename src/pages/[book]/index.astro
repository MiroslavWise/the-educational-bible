---
import { getCollection } from "astro:content"
import Layout from "../../layouts/Layout.astro"
import BookPage from "../../components/BookPage"
import { bookDescription, bookTitle } from "../../lib/seo"

export async function getStaticPaths() {
  const entries = await getCollection("books")
  return entries.map((e) => ({
    params: { book: e.data.slug },
    props: { data: e.data },
  }))
}

const { data } = Astro.props
const book = {
  slug: data.slug,
  name: data.name,
  fullName: data.fullName,
  testament: data.testament,
  chaptersCount: data.chaptersCount,
  introduction: data.introduction,
  articles: data.articles,
}

const introText = data.introduction
  .flatMap((s) => s.paragraphs)
  .find((p) => p.trim().length > 40)

const path = `/${data.slug}/`
const title = bookTitle(data.fullName)
const description = bookDescription(data.fullName, data.chaptersCount, introText)

const jsonLd = [
  {
    "@type": "Book",
    name: data.fullName,
    alternateName: data.name,
    url: new URL(path, Astro.site).href,
    inLanguage: "ru",
    numberOfPages: data.chaptersCount,
    description,
    isPartOf: {
      "@type": "Book",
      name: "Новая учебная Женевская Библия",
    },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Главная",
        item: Astro.site?.href ?? "/",
      },
      {
        "@type": "ListItem",
        position: 2,
        name: data.name,
        item: new URL(path, Astro.site).href,
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  path={path}
  ogType="website"
  jsonLd={jsonLd}
>
  <BookPage client:load book={book} />
</Layout>
