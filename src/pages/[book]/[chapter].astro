---
import { getCollection } from "astro:content"
import type { Thing } from "schema-dts"
import Layout from "../../layouts/Layout.astro"
import ChapterPage from "../../components/ChapterPage"
import { chapterNav, getChapter } from "../../lib/bible"
import {
  OG_IMAGE_PATH,
  absoluteUrl,
  chapterDescription,
  chapterKeywords,
  chapterTitle,
} from "../../lib/seo"

export async function getStaticPaths() {
  const entries = await getCollection("books")
  const paths = []
  for (const e of entries) {
    for (const ch of e.data.chapters) {
      paths.push({
        params: { book: e.data.slug, chapter: String(ch.number) },
        props: { data: e.data, chapterNumber: ch.number },
      })
    }
  }
  return paths
}

const { data, chapterNumber } = Astro.props
const chapter = getChapter(data, chapterNumber)!
const nav = chapterNav(data, chapterNumber)
const book = { slug: data.slug, name: data.name, chaptersCount: data.chaptersCount }

const path = `/${data.slug}/${chapterNumber}/`
const title = chapterTitle(data.name, chapterNumber)
const description = chapterDescription(
  data.name,
  chapterNumber,
  chapter.verses.map((v) => v.text),
)
const keywords = chapterKeywords(data.name, chapterNumber)
const pageUrl = absoluteUrl(path, Astro.site)
const bookUrl = absoluteUrl(`/${data.slug}/`, Astro.site)
const imageUrl = absoluteUrl(OG_IMAGE_PATH, Astro.site)
const homeUrl = Astro.site?.href ?? "https://the-educational-bible.web.app/"

const jsonLd: Thing[] = [
  {
    "@type": "Chapter",
    name: `${data.name}, глава ${chapterNumber}`,
    headline: `${data.name}. Глава ${chapterNumber}`,
    url: pageUrl,
    inLanguage: "ru",
    description,
    keywords,
    image: imageUrl,
    isPartOf: {
      "@type": "Book",
      name: data.fullName,
      url: bookUrl,
    },
    hasPart: chapter.verses.slice(0, 5).map((v) => ({
      "@type": "CreativeWork",
      position: v.number,
      text: v.text,
    })),
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Главная",
        item: homeUrl,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: data.name,
        item: bookUrl,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: `Глава ${chapterNumber}`,
        item: pageUrl,
      },
    ],
  },
]
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  path={path}
  ogType="article"
  jsonLd={jsonLd}
>
  <ChapterPage client:load book={book} chapter={chapter} nav={nav} />
</Layout>
