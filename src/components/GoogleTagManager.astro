---
/** Google Tag Manager — only on production builds. */
const containerId = import.meta.env.GOOGLE_TAG_MANAGER_ID || "GTM-N3QC3SN9"
const enabled = import.meta.env.PROD && Boolean(containerId)

interface Props {
  /** head = script in <head>; body = noscript after <body> */
  placement: "head" | "body"
}

const { placement } = Astro.props
---

{
  enabled && placement === "head" && (
    <script is:inline define:vars={{ containerId }}>
      ;(function (w, d, s, l, i) {
        w[l] = w[l] || []
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" })
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : ""
        j.async = true
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl
        f.parentNode.insertBefore(j, f)
      })(window, document, "script", "dataLayer", containerId)
    </script>
  )
}

{
  enabled && placement === "body" && (
    <noscript>
      <iframe
        src={`https://www.googletagmanager.com/ns.html?id=${containerId}`}
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      />
    </noscript>
  )
}
